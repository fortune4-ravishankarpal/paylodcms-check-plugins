{
  "name": "webscraping",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "seed": "tsx -r dotenv/config src/seed/script.ts",
    "seed:one": "tsx -r dotenv/config scripts/seed-one.ts",
    "nuke": "pnpm payload migrate:fresh && pnpm seed",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@hookform/error-message": "^2.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@nouance/payload-better-fields-plugin": "^2.0.2",
    "@opensearch-project/opensearch": "^3.6.0",
    "@payload-bites/audit-fields": "^1.6.0",
    "@payload-bites/content-freeze": "^1.2.0",
    "@payload-enchants/translator": "^1.3.0",
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/db-sqlite": "3.84.1",
    "@payloadcms/email-nodemailer": "^3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-import-export": "^3.84.1",
    "@payloadcms/plugin-multi-tenant": "^3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@payloadcmsdirectory/shadcn-ui": "^0.2.14",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@veiag/payload-enhanced-sidebar": "^0.3.1",
    "axios": "^1.15.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "country-state-city": "^3.2.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "immer": "^11.1.4",
    "ioredis": "^5.10.1",
    "lucide-react": "0.563.0",
    "next": "16.2.3",
    "next-sitemap": "^4.2.3",
    "payload": "3.84.1",
    "payload-crowdin-sync": "^0.41.0",
    "payload-gatekeeper": "^1.1.0",
    "payload-plugin-comments": "^1.0.2",
    "pg": "^8.20.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "7.71.1",
    "react-select": "^5.10.2",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.4.1",
    "zod-validation-error": "^5.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "28.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
